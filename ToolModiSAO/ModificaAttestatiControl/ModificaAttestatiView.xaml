<Window x:Class="ToolModiSAO.ModificaAttestatiControl.ModificaAttestatiView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Modifica Attestato" Height="820" Width="600"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20" Style="{StaticResource TotaleSfondo}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ID -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="ID"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="0" Grid.Column="1"
                           Text="{Binding Attestato.Id}"
                           IsReadOnly="True" Background="#F0F0F0"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Attivo -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Attivo"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="1" Grid.Column="1"
                           Text="{Binding Attestato.Attivo, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Matricola -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Matricola"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="2" Grid.Column="1"
                           Text="{Binding Attestato.MatricolaDipendente, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Dipendente -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Dipendente"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="3" Grid.Column="1"
                           Text="{Binding Attestato.Dipendente, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Titolo Corso -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Titolo Corso"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="4" Grid.Column="1"
                           Text="{Binding Attestato.TitoloCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Attività Formativa -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Attività Formativa"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="5" Grid.Column="1"
                           Text="{Binding Attestato.AttivitaFormativa, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Materia Corso -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Materia Corso"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="6" Grid.Column="1"
                           Text="{Binding Attestato.MateriaCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Tipologia Corso -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Tipologia Corso"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="7" Grid.Column="1"
                           Text="{Binding Attestato.TipologiaCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Ente Formatore -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Ente Formatore"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="8" Grid.Column="1"
                           Text="{Binding Attestato.EnteFormatore, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Denom. Formatore -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Denom. Formatore"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="9" Grid.Column="1"
                           Text="{Binding Attestato.DenominazioneEnteFormatore, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Denom. Certificatore -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Denom. Certificatore"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="10" Grid.Column="1"
                           Text="{Binding Attestato.DenominazioneEnteCertificatore, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Data Inizio -->
                <TextBlock Grid.Row="11" Grid.Column="0" Text="Data Inizio"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="11" Grid.Column="1"
                           Text="{Binding Attestato.DataInizioCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Data Fine -->
                <TextBlock Grid.Row="12" Grid.Column="0" Text="Data Fine"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="12" Grid.Column="1"
                           Text="{Binding Attestato.DataFineCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Data Normalizzata -->
                <TextBlock Grid.Row="13" Grid.Column="0" Text="Data Normalizzata"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="13" Grid.Column="1"
                           Text="{Binding Attestato.DataNormalizzata, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Anno Corso -->
                <TextBlock Grid.Row="14" Grid.Column="0" Text="Anno Corso"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="14" Grid.Column="1"
                           Text="{Binding Attestato.AnnoCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Validità (anni) -->
                <TextBlock Grid.Row="15" Grid.Column="0" Text="Validità (anni)"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="15" Grid.Column="1"
                           Text="{Binding Attestato.ValiditaAnni, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Data Scadenza -->
                <TextBlock Grid.Row="16" Grid.Column="0" Text="Data Scadenza"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="16" Grid.Column="1"
                           Text="{Binding Attestato.DataScadenzaCorso, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Link Attestato -->
                <TextBlock Grid.Row="17" Grid.Column="0" Text="Link Attestato"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="17" Grid.Column="1"
                           Text="{Binding Attestato.LinkAttestato, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Reparto -->
                <TextBlock Grid.Row="18" Grid.Column="0" Text="Reparto"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="18" Grid.Column="1"
                           Text="{Binding Attestato.Reparto, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Sezione -->
                <TextBlock Grid.Row="19" Grid.Column="0" Text="Sezione"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="19" Grid.Column="1"
                           Text="{Binding Attestato.Sezione, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Nucleo -->
                <TextBlock Grid.Row="20" Grid.Column="0" Text="Nucleo"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="20" Grid.Column="1"
                           Text="{Binding Attestato.Nucleo, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Cod. Ufficio -->
                <TextBlock Grid.Row="21" Grid.Column="0" Text="Cod. Ufficio"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Center" Margin="0,6,10,6"/>
                <TextBox   Grid.Row="21" Grid.Column="1"
                           Text="{Binding Attestato.CodUfficio, UpdateSourceTrigger=PropertyChanged}"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

                <!-- Note -->
                <TextBlock Grid.Row="22" Grid.Column="0" Text="Note"
                           Style="{DynamicResource WhiteBoldText}"
                           VerticalAlignment="Top" Margin="0,10,10,6"/>
                <TextBox   Grid.Row="22" Grid.Column="1"
                           Text="{Binding Attestato.Note, UpdateSourceTrigger=PropertyChanged}"
                           Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                           VerticalScrollBarVisibility="Auto"
                           HorizontalAlignment="Stretch" Margin="0,4"/>

            </Grid>
        </ScrollViewer>

        <!-- Pulsanti -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Annulla" Command="{Binding AnnullaCommand}"
                    Style="{StaticResource NavyButtonStyle}" HorizontalAlignment="Left" Width="150"/>

            <Button Grid.Column="1" Content="Elimina" Command="{Binding EliminaCommand}"
                    Style="{DynamicResource NavyButtonStyle}" Background="Red"
                    HorizontalAlignment="Center" Width="150"/>

            <Button Grid.Column="2" Content="Salva" Command="{Binding SalvaCommand}"
                    Style="{StaticResource NavyButtonStyle}" HorizontalAlignment="Right" Width="150"/>
        </Grid>
    </Grid>
</Window>